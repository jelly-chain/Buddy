{
  "name": "buddy",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "description": "macOS AI agent — coder, blockchain expert, site builder, scheduler",
  "scripts": {
    "start": "bash start-buddy.sh",
    "proxy": "node proxy.mjs",
    "health": "curl -s http://127.0.0.1:${PROXY_PORT:-7788}/health | node -e \"process.stdin.resume();let d='';process.stdin.on('data',c=>d+=c);process.stdin.on('end',()=>console.log(JSON.parse(d)))\""
  },
  "dependencies": {
    "@openrouter/sdk": "^0.12.19",
    "@solana/web3.js": "^1.98.0",
    "ethers": "^6.13.0",
    "node-cron": "^3.0.3",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  }
}

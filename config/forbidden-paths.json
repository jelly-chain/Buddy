{
  "paths": [
    ".env",
    ".env.local",
    ".env.production",
    "**/.ssh/**",
    "**/id_rsa",
    "**/id_rsa.pub",
    "**/id_ed25519",
    "**/id_ed25519.pub",
    "**/*.pem",
    "**/*.key",
    "**/wallet.json",
    "**/keystore/**",
    "**/.aws/credentials",
    "**/.config/gh/hosts.yml",
    "**/Library/Keychains/**"
  ],
  "note": "Tools should refuse reads/writes to any path matching these globs unless the user explicitly names the file in the current request."
}
